<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Travel Persona Explorer - Assignment 2</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">

  <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

  <script src="https://cdn.amcharts.com/lib/5/index.js"></script>
  <script src="https://cdn.amcharts.com/lib/5/map.js"></script>
  <script src="https://cdn.amcharts.com/lib/5/geodata/worldLow.js"></script>
  <script src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>
</head>

<body class="bg-travel">
  <div id="app" v-cloak>
    <nav class="navbar navbar-expand-lg navbar-dark app-nav">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">Travel Persona Explorer</a>
      </div>
    </nav>

    <div class="container py-4 py-md-5">
      <div class="row g-4">
        <div class="col-12 col-lg-4">
          <div class="card glass-card shadow-lg border-0 h-100">
            <div class="card-body p-4">
              <h2 class="h4 mb-3">Quick Survey</h2>
              <p class="text-muted mb-4">
                Submit the form and charts will update instantly without page refresh.
              </p>

              <form @submit.prevent="submitSurvey">
                <div class="mb-3">
                  <label class="form-label fw-semibold">What best describes your travel style?</label>
                  <select v-model="form.travelStyle" class="form-select" required>
                    <option value="">Select...</option>
                    <option>Backpacking & Adventure</option>
                    <option>Luxury & Comfort</option>
                    <option>Solo Exploration</option>
                    <option>Romantic Getaway</option>
                    <option>Family Vacation</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">How often do you travel internationally?</label>
                  <select v-model="form.travelFrequency" class="form-select" required>
                    <option value="">Select...</option>
                    <option>Rarely</option>
                    <option>Once a year</option>
                    <option>2–3 times per year</option>
                    <option>More than 3 times per year</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">Which continent is at the top of your travel bucket list?</label>
                  <select v-model="form.dreamContinent" class="form-select" required>
                    <option value="">Select...</option>
                    <option>Europe</option>
                    <option>Asia</option>
                    <option>North America</option>
                    <option>South America</option>
                    <option>Africa</option>
                    <option>Oceania</option>
                  </select>
                </div>

                <div class="mb-4">
                  <label class="form-label fw-semibold">What is your typical budget per international trip?</label>
                  <select v-model="form.budgetRange" class="form-select" required>
                    <option value="">Select...</option>
                    <option>Under $1000</option>
                    <option>$1000–$3000</option>
                    <option>$3000–$5000</option>
                    <option>Over $5000</option>
                  </select>
                </div>

                <button class="btn btn-primary w-100" :disabled="loading">
                  {{ loading ? "Submitting..." : "Submit" }}
                </button>
              </form>

              <p v-if="message" class="mt-3 mb-0 small" :class="messageClass">
                {{ message }}
              </p>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-8" v-once>
          <div class="row g-4">
            <div class="col-12 col-xl-6">
              <div class="card chart-card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h3 class="h5 mb-3">Travel Style Distribution</h3>
                  <div id="pieChart"></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-xl-6">
              <div class="card chart-card shadow-sm border-0 h-100">
                <div class="card-body">
                  <h3 class="h5 mb-3">Travel Frequency Overview</h3>
                  <div id="barChart"></div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card chart-card shadow-sm border-0">
                <div class="card-body">
                  <h3 class="h5 mb-3">Budget Range Overview</h3>
                  <div id="budgetChart"></div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card chart-card shadow-sm border-0">
                <div class="card-body">
                  <h3 class="h5 mb-3">Dream Destinations by Continent</h3>
                  <div id="mapChart"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card table-card shadow-sm border-0 mt-4">
        <div class="card-body">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
            <h3 class="h5 mb-0">Survey Responses Table</h3>

            <div class="table-search">
              <input
                v-model="searchQuery"
                @input="handleSearchInput"
                type="text"
                class="form-control"
                placeholder="Search by style, frequency, continent or budget..."
              >
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-3">
              <thead class="table-light">
                <tr>
                  <th>Travel Style</th>
                  <th>Travel Frequency</th>
                  <th>Dream Continent</th>
                  <th>Budget Range</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="row in responses" :key="row._id">
                  <td>{{ row.travelStyle }}</td>
                  <td>{{ row.travelFrequency }}</td>
                  <td>{{ row.dreamContinent }}</td>
                  <td>{{ row.budgetRange }}</td>
                </tr>
                <tr v-if="responses.length === 0">
                  <td colspan="4" class="text-center text-muted py-4">
                    No matching responses found.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">
              Showing page {{ page }} of {{ totalPages }}
            </small>

            <div class="btn-group" role="group" aria-label="Pagination controls">
              <button
                type="button"
                class="btn btn-outline-primary btn-sm"
                :disabled="page <= 1"
                @click="page--; loadResponses()"
              >
                Previous
              </button>

              <button
                type="button"
                class="btn btn-outline-primary btn-sm"
                :disabled="page >= totalPages"
                @click="page++; loadResponses()"
              >
                Next
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/iso2ToContinent.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>